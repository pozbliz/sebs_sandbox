# This .gitignore is appropriate for repositories deployed to GitHub Pages and using
# a Gemfile as specified at https://github.com/github/pages-gem#conventional

# Basic Jekyll gitignores (synchronize to Jekyll.gitignore)
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata

# Additional Ruby/bundler ignore for when you run: bundle install
/vendor
.bundle

# Dependency lockfile is regenerated locally and not required by Chirpy Starter.
Gemfile.lock
*.gem
node_modules
package-lock.json
_sass/vendors
assets/js/dist

# Exclude folder to avoid publishing draft articles
draft/*

# Local review guidance for Codex article-review skill
editorial-brief.md

# Jetbrains IDE folder
.idea/*
